#!/usr/bin/env bash
set -euo pipefail
DOTFILES_REPO="https://github.com/pduchnovsky/dotfiles.git"
DOTFILES_DIR="$HOME/.dotfiles"
BACKUP_DIR="$HOME/.dotfiles-backup"
BREWFILE="$HOME/Brewfile"

if ! command -v brew &>/dev/null; then
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  [[ "$(uname)" == "Darwin" ]] && { [[ -x /opt/homebrew/bin/brew ]] && eval "$(/opt/homebrew/bin/brew shellenv)" || eval "$(/usr/local/bin/brew shellenv)"; } || eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

git config --global fetch.prune true
git config --global push.autoSetupRemote true
git clone --bare "$DOTFILES_REPO" "$DOTFILES_DIR"

cfg() { git --git-dir="$DOTFILES_DIR" --work-tree="$HOME" "$@"; }

if ! cfg checkout 2>/dev/null; then
  mkdir -p "$BACKUP_DIR"
  cfg checkout 2>&1 | grep -E "^\s+\." | awk '{print $1}' | while read -r f; do
    mkdir -p "$(dirname "$BACKUP_DIR/$f")"
    mv "$HOME/$f" "$BACKUP_DIR/$f"
  done
  cfg checkout
fi

cfg config status.showUntrackedFiles no
cfg config user.email "54581833+pduchnovsky@users.noreply.github.com"
cfg config user.name "Peter Duchnovsky"

[[ -f "$BREWFILE" ]] && brew bundle install --file="$BREWFILE"
